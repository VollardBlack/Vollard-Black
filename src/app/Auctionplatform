// ─── AUCTION CARD ───
function AuctionCard({ auction, bids, fmt, actions, onSelect, onBid }) {
  const remaining = useCountdown(auction.endTime, auction.status);
  const auctionBids = bids.filter(b => b.auctionId === auction.id);
  const sc = auctionStatusColor[auction.status] || auctionStatusColor.Draft;
  const reserveMet = (auction.currentBid || 0) >= (auction.reservePrice || 0);

  return (
    <div style={{ background:"#f7f5f1", border:"1px solid rgba(182,139,46,0.20)", borderRadius:14, overflow:"hidden" }}>
      <div style={{ height:3, background:sc.c }} />
      <div style={{ padding:20 }}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", marginBottom:12 }}>
          <div>
            <div style={{ fontFamily:"Cormorant Garamond,serif", fontSize:18, fontWeight:400, color:"#1a1714" }}>{auction.title}</div>
            <div style={{ fontSize:11, color:"#8a8070", marginTop:2 }}>{auction.artist} · {auction.galleryName}</div>
          </div>
          <span style={{ padding:"4px 10px", borderRadius:6, fontSize:11, fontWeight:600, background:sc.bg, color:sc.c, flexShrink:0 }}>{auction.status}</span>
        </div>

        <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8, marginBottom:14 }}>
          <div style={{ background:"#e8e4dd", borderRadius:8, padding:"10px 12px" }}>
            <div style={{ fontSize:9, letterSpacing:2, textTransform:"uppercase", color:"#8a8070", marginBottom:4 }}>Current Bid</div>
            <div style={{ fontFamily:"Cormorant Garamond,serif", fontSize:20, fontWeight:600, color:"#b68b2e" }}>R {fmt(auction.currentBid||0)}</div>
          </div>
          <div style={{ background:"#e8e4dd", borderRadius:8, padding:"10px 12px" }}>
            <div style={{ fontSize:9, letterSpacing:2, textTransform:"uppercase", color:"#8a8070", marginBottom:4 }}>Reserve</div>
            <div style={{ fontFamily:"Cormorant Garamond,serif", fontSize:20, fontWeight:600, color:reserveMet?"#4a9e6b":"#c45c4a" }}>R {fmt(auction.reservePrice||0)}</div>
          </div>
        </div>

        {auction.status === "Live" && remaining !== null && (
          <div style={{ textAlign:"center", padding:"8px", background:"rgba(182,139,46,0.08)", borderRadius:8, marginBottom:12 }}>
            <div style={{ fontSize:9, letterSpacing:2, textTransform:"uppercase", color:"#8a8070" }}>Time Remaining</div>
            <div style={{ fontFamily:"Cormorant Garamond,serif", fontSize:24, fontWeight:400, color:remaining<300000?"#c45c4a":"#1a1714" }}>{formatCountdown(remaining)}</div>
          </div>
        )}

        <div style={{ fontSize:11, color:"#6b635a", marginBottom:14 }}>{auctionBids.length} bid{auctionBids.length!==1?"s":""} · Increment: {auction.incrementLabel}</div>

        <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
          {auction.status === "Draft" && (
            <button onClick={() => actions.launchAuction(auction.id)} style={{ flex:1, padding:"10px", background:"linear-gradient(135deg,#4a9e6b,#2d7a4a)", border:"none", borderRadius:8, color:"#fff", fontSize:11, fontWeight:600, letterSpacing:1, textTransform:"uppercase", cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>
              🚀 Launch
            </button>
          )}
          {auction.status === "Live" && (
            <>
              <button onClick={onBid} style={{ flex:1, padding:"10px", background:"linear-gradient(135deg,#b68b2e,#8a6a1e)", border:"none", borderRadius:8, color:"#f5f3ef", fontSize:11, fontWeight:600, letterSpacing:1, textTransform:"uppercase", cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>
                Place Bid
              </button>
              <button onClick={() => actions.freezeAuction(auction.id)} style={{ padding:"10px 14px", background:"rgba(100,140,200,0.12)", border:"1px solid rgba(100,140,200,0.3)", borderRadius:8, color:"#648cc8", fontSize:11, fontWeight:600, cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>
                ⏸ Freeze
              </button>
              <button onClick={() => { if(confirm("Close auction?")) actions.closeAuction(auction.id); }} style={{ padding:"10px 14px", background:"rgba(196,92,74,0.12)", border:"1px solid rgba(196,92,74,0.3)", borderRadius:8, color:"#c45c4a", fontSize:11, fontWeight:600, cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>
                Close
              </button>
            </>
          )}
          {auction.status === "Frozen" && (
            <>
              <button onClick={() => actions.resumeAuction(auction.id)} style={{ flex:1, padding:"10px", background:"linear-gradient(135deg,#4a9e6b,#2d7a4a)", border:"none", borderRadius:8, color:"#fff", fontSize:11, fontWeight:600, letterSpacing:1, textTransform:"uppercase", cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>
                ▶ Resume
              </button>
              <button onClick={() => { if(confirm("Close auction?")) actions.closeAuction(auction.id); }} style={{ padding:"10px 14px", background:"rgba(196,92,74,0.12)", border:"1px solid rgba(196,92,74,0.3)", borderRadius:8, color:"#c45c4a", fontSize:11, fontWeight:600, cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>
                Close
              </button>
            </>
          )}
        </div>
      </div>
    </div>
  );
}

// ─── AUCTION MANAGE ROW (detailed) ───
function AuctionManageRow({ auction, bids, buyers, collectors, fmt, actions, onBid, onReport }) {
  const [expanded, setExpanded] = React.useState(true);
  const remaining = useCountdown(auction.endTime, auction.status);
  const auctionBids = bids.filter(b => b.auctionId === auction.id).sort((a,b) => new Date(b.timestamp)-new Date(a.timestamp));
  const sc = auctionStatusColor[auction.status] || auctionStatusColor.Draft;
  const reserveMet = (auction.currentBid||0) >= (auction.reservePrice||0);
  const winner = buyers.find(b => b.id === auction.leadBidderId);

  return (
    <div style={{ background:"#f7f5f1", border:"1px solid rgba(182,139,46,0.20)", borderRadius:14, overflow:"hidden" }}>
      <div style={{ height:4, background:sc.c }} />
      <div style={{ padding:20 }}>
        <div style={{ display:"flex", gap:16, alignItems:"flex-start", flexWrap:"wrap" }}>
          <div style={{ flex:1, minWidth:200 }}>
            <div style={{ display:"flex", alignItems:"center", gap:10, marginBottom:6 }}>
              <span style={{ fontFamily:"Cormorant Garamond,serif", fontSize:20, fontWeight:400, color:"#1a1714" }}>{auction.title}</span>
              <span style={{ padding:"3px 10px", borderRadius:6, fontSize:11, fontWeight:600, background:sc.bg, color:sc.c }}>{auction.status}</span>
              {auction.status==="Live" && <span style={{ fontSize:10, color:"#4a9e6b", fontWeight:600 }}>● LIVE</span>}
            </div>
            <div style={{ fontSize:12, color:"#6b635a" }}>{auction.artist} · {auction.galleryName}</div>
            <div style={{ display:"flex", gap:16, fontSize:12, marginTop:8, flexWrap:"wrap" }}>
              <span>Reserve: <strong style={{ color:reserveMet?"#4a9e6b":"#c45c4a" }}>R {fmt(auction.reservePrice||0)}</strong></span>
              <span>Current: <strong style={{ color:"#b68b2e" }}>R {fmt(auction.currentBid||0)}</strong></span>
              <span>{auctionBids.length} bid{auctionBids.length!==1?"s":""}</span>
              <span>Increment: {auction.incrementLabel}</span>
              {remaining!==null && <span style={{ color:remaining<300000?"#c45c4a":"#4a9e6b", fontWeight:600 }}>⏱ {formatCountdown(remaining)}</span>}
            </div>
            {winner && (
              <div style={{ marginTop:8, fontSize:12, color:"#4a9e6b" }}>
                🏆 Lead bidder: <strong>{winner.type==="company"?winner.companyName:`${winner.firstName} ${winner.lastName}`}</strong>
              </div>
            )}
          </div>

          <div style={{ display:"flex", gap:8, flexWrap:"wrap", alignItems:"center" }}>
            {auction.status==="Draft" && <button onClick={()=>actions.launchAuction(auction.id)} style={{ padding:"10px 18px", background:"linear-gradient(135deg,#4a9e6b,#2d7a4a)", border:"none", borderRadius:8, color:"#fff", fontSize:11, fontWeight:600, letterSpacing:1, textTransform:"uppercase", cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>🚀 Launch</button>}
            {auction.status==="Live" && <>
              <button onClick={onBid} style={{ padding:"10px 18px", background:"linear-gradient(135deg,#b68b2e,#8a6a1e)", border:"none", borderRadius:8, color:"#f5f3ef", fontSize:11, fontWeight:600, letterSpacing:1, textTransform:"uppercase", cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>Place Bid</button>
              <button onClick={()=>actions.freezeAuction(auction.id)} style={{ padding:"10px 14px", background:"rgba(100,140,200,0.12)", border:"1px solid rgba(100,140,200,0.3)", borderRadius:8, color:"#648cc8", fontSize:11, fontWeight:600, cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>⏸ Freeze</button>
              <button onClick={()=>{if(confirm("Close this auction now?"))actions.closeAuction(auction.id);}} style={{ padding:"10px 14px", background:"rgba(196,92,74,0.12)", border:"1px solid rgba(196,92,74,0.3)", borderRadius:8, color:"#c45c4a", fontSize:11, fontWeight:600, cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>Close</button>
            </>}
            {auction.status==="Frozen" && <>
              <button onClick={()=>actions.resumeAuction(auction.id)} style={{ padding:"10px 18px", background:"linear-gradient(135deg,#4a9e6b,#2d7a4a)", border:"none", borderRadius:8, color:"#fff", fontSize:11, fontWeight:600, letterSpacing:1, textTransform:"uppercase", cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>▶ Resume</button>
              <button onClick={()=>{if(confirm("Close this auction now?"))actions.closeAuction(auction.id);}} style={{ padding:"10px 14px", background:"rgba(196,92,74,0.12)", border:"1px solid rgba(196,92,74,0.3)", borderRadius:8, color:"#c45c4a", fontSize:11, fontWeight:600, cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>Close</button>
            </>}
            <button onClick={onReport} style={{ padding:"10px 14px", background:"transparent", border:"1px solid rgba(182,139,46,0.3)", borderRadius:8, color:"#b68b2e", fontSize:11, fontWeight:600, cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>📄 Report</button>
            <button onClick={()=>setExpanded(p=>!p)} style={{ background:"none", border:"1px solid rgba(182,139,46,0.3)", borderRadius:6, color:"#6b635a", cursor:"pointer", padding:"8px 12px", fontSize:11 }}>
              {expanded?"▲":"▼"} Bids
            </button>
          </div>
        </div>

        {expanded && (
          <div style={{ marginTop:16, borderTop:"1px solid rgba(182,139,46,0.12)", paddingTop:16 }}>
            {auctionBids.length === 0 ? (
              <p style={{ fontSize:13, color:"#8a8070" }}>No bids yet.</p>
            ) : (
              <div style={{ overflowX:"auto" }}>
                <table style={{ width:"100%", borderCollapse:"collapse" }}>
                  <thead>
                    <tr>
                      {["#","Bidder","Amount","Time","Status"].map((h,i) => (
                        <th key={i} style={{ fontSize:10, fontWeight:600, letterSpacing:1.5, textTransform:"uppercase", color:"#8a8070", padding:"8px 10px", textAlign:i>1?"right":"left", borderBottom:"1px solid rgba(182,139,46,0.18)" }}>{h}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {auctionBids.map((b,i) => (
                      <tr key={b.id} style={{ background:i===0?"rgba(182,139,46,0.05)":"transparent" }}>
                        <td style={{ padding:"8px 10px", borderBottom:"1px solid rgba(182,139,46,0.08)", fontSize:12, color:"#8a8070" }}>{auctionBids.length-i}</td>
                        <td style={{ padding:"8px 10px", borderBottom:"1px solid rgba(182,139,46,0.08)", fontSize:13, fontWeight:i===0?600:400, color:"#1a1714" }}>{b.buyerName}</td>
                        <td style={{ padding:"8px 10px", borderBottom:"1px solid rgba(182,139,46,0.08)", textAlign:"right", fontSize:13, fontWeight:600, color:"#b68b2e" }}>R {fmt(b.amount)}</td>
                        <td style={{ padding:"8px 10px", borderBottom:"1px solid rgba(182,139,46,0.08)", textAlign:"right", fontSize:11, color:"#8a8070" }}>{b.timestamp.slice(0,16).replace("T"," ")}</td>
                        <td style={{ padding:"8px 10px", borderBottom:"1px solid rgba(182,139,46,0.08)", textAlign:"right" }}>
                          {i===0 ? <span style={{ fontSize:11, fontWeight:600, color:"#4a9e6b" }}>LEAD</span> : <span style={{ fontSize:11, color:"#8a8070" }}>Outbid</span>}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}

