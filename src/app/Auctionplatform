  const approved = buyers.filter(b => b.auctionApproved);
  const bn = b => b.type==="company" ? b.companyName : `${b.firstName} ${b.lastName}`;

  return (
    <div>
      <div style={{ marginBottom:16, padding:"12px 16px", background:"rgba(182,139,46,0.08)", border:"1px solid rgba(182,139,46,0.2)", borderRadius:10, fontSize:13, color:"#6b635a" }}>
        Buyers must register their interest to participate in auctions. Once you verify their KYC details are complete, approve them here. Only approved buyers can place bids.
      </div>

      {pending.length > 0 && (
        <div style={{ marginBottom:28 }}>
          <div style={{ fontSize:11, letterSpacing:2, textTransform:"uppercase", color:"#dc7828", marginBottom:14 }}>Pending Approval ({pending.length})</div>
          <div style={{ display:"grid", gap:10 }}>
            {pending.map(b => (
              <div key={b.id} style={{ display:"flex", alignItems:"center", gap:16, padding:"14px 18px", background:"rgba(220,120,40,0.06)", border:"1px solid rgba(220,120,40,0.2)", borderRadius:10, flexWrap:"wrap" }}>
                <div style={{ flex:1, minWidth:200 }}>
                  <div style={{ fontSize:14, fontWeight:600, color:"#1a1714" }}>{bn(b)}</div>
                  <div style={{ fontSize:12, color:"#6b635a", marginTop:2 }}>{b.email} · ID: {b.idNumber||"—"} · {b.nationality||"—"}</div>
                  <div style={{ fontSize:11, color:"#dc7828", marginTop:4 }}>KYC: {b.idNumber?"✓ ID on file":"⚠ No ID"} · {b.email?"✓ Email":"⚠ No email"} · Requested: {b.auctionRequestedAt||"—"}</div>
                </div>
                <div style={{ display:"flex", gap:8 }}>
                  <button onClick={() => actions.approveForAuction(b.id)} style={{ padding:"8px 16px", background:"linear-gradient(135deg,#4a9e6b,#2d7a4a)", border:"none", borderRadius:8, color:"#fff", fontSize:11, fontWeight:600, cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>✓ Approve</button>
                  <button onClick={() => actions.revokeAuctionApproval(b.id)} style={{ padding:"8px 14px", background:"rgba(196,92,74,0.12)", border:"1px solid rgba(196,92,74,0.3)", borderRadius:8, color:"#c45c4a", fontSize:11, fontWeight:600, cursor:"pointer", fontFamily:"DM Sans,sans-serif" }}>Decline</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <div>
        <div style={{ fontSize:11, letterSpacing:2, textTransform:"uppercase", color:"#4a9e6b", marginBottom:14 }}>Approved Buyers ({approved.length})</div>
        {approved.length === 0 ? (
          <p style={{ fontSize:13, color:"#8a8070" }}>No approved buyers yet.</p>
        ) : (
          <div style={{ overflowX:"auto" }}>
            <table style={{ width:"100%", borderCollapse:"collapse" }}>
              <thead>
                <tr>
                  {["Name","Email","ID / Reg","Nationality","Approved",""].map((h,i) => (
                    <th key={i} style={{ fontSize:10, fontWeight:600, letterSpacing:1.5, textTransform:"uppercase", color:"#8a8070", padding:"10px 12px", textAlign:"left", borderBottom:"1px solid rgba(182,139,46,0.18)" }}>{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {approved.map(b => (
                  <tr key={b.id}>
                    <td style={{ padding:"10px 12px", borderBottom:"1px solid rgba(182,139,46,0.10)", fontSize:13, fontWeight:600, color:"#1a1714" }}>{bn(b)}</td>
                    <td style={{ padding:"10px 12px", borderBottom:"1px solid rgba(182,139,46,0.10)", fontSize:12, color:"#6b635a" }}>{b.email||"—"}</td>
                    <td style={{ padding:"10px 12px", borderBottom:"1px solid rgba(182,139,46,0.10)", fontSize:12, color:"#6b635a" }}>{b.idNumber||"—"}</td>
                    <td style={{ padding:"10px 12px", borderBottom:"1px solid rgba(182,139,46,0.10)", fontSize:12, color:"#6b635a" }}>{b.nationality||"—"}</td>
                    <td style={{ padding:"10px 12px", borderBottom:"1px solid rgba(182,139,46,0.10)" }}><span style={{ fontSize:11, fontWeight:600, color:"#4a9e6b" }}>✓ Approved {b.auctionApprovedAt||""}</span></td>
                    <td style={{ padding:"10px 12px", borderBottom:"1px solid rgba(182,139,46,0.10)" }}>
                      <button onClick={() => actions.revokeAuctionApproval(b.id)} style={{ background:"none", border:"1px solid rgba(196,92,74,0.3)", borderRadius:6, color:"#c45c4a", cursor:"pointer", padding:"4px 10px", fontSize:11, fontFamily:"DM Sans,sans-serif" }}>Revoke</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      {/* Manually mark a buyer as requesting approval */}
      <div style={{ marginTop:28 }}>
        <div style={{ fontSize:11, letterSpacing:2, textTransform:"uppercase", color:"#8a8070", marginBottom:14 }}>Mark Buyer as Requesting Auction Access</div>
        <RequestAuctionAccess buyers={buyers.filter(b=>!b.auctionApproved&&!b.auctionRequested)} actions={actions} />
      </div>
    </div>
  );
}

function RequestAuctionAccess({ buyers, actions }) {
  const [selected, setSelected] = React.useState("");
  const bn = b => b.type==="company" ? b.companyName : `${b.firstName} ${b.lastName}`;
  return (
    <div style={{ display:"flex", gap:10, alignItems:"center" }}>
      <select value={selected} onChange={e=>setSelected(e.target.value)} style={{ flex:1, padding:"10px 14px", background:"#e8e4dd", border:"1px solid rgba(182,139,46,0.20)", borderRadius:8, color:"#1a1714", fontFamily:"DM Sans,sans-serif", fontSize:13, outline:"none" }}>
        <option value="">— Select buyer to mark as requesting access</option>
        {buyers.map(b => <option key={b.id} value={b.id}>{bn(b)}</option>)}
      </select>
      <button disabled={!selected} onClick={() => {
        if (!selected) return;
        actions.updateBuyerAuctionRequest && actions.updateBuyerAuctionRequest(selected);
        setSelected("");
      }} style={{ padding:"10px 18px", background:"rgba(182,139,46,0.15)", border:"1px solid rgba(182,139,46,0.3)", borderRadius:8, color:"#b68b2e", fontSize:11, fontWeight:600, cursor:selected?"pointer":"not-allowed", opacity:selected?1:0.4, fontFamily:"DM Sans,sans-serif" }}>
        Mark as Requesting
      </button>
    </div>
  );
}

// ─── CREATE AUCTION MODAL ───
function CreateAuctionModal({ artworks, collectors, schedules, onSave, onClose, fmt }) {
  const [f, setF] = React.useState({
    title:"", artist:"", artworkId:"", artworkValue:0, reservePrice:0,
    galleryName:"", incrementType:"pct", incrementValue:0.025, incrementLabel:"2.5%",
    endTime:"", startNote:"",
  });
  const s = (k,v) => setF(p => ({...p,[k]:v}));

  const availableArtworks = artworks.filter(a => ["Available","Reserved","In Gallery"].includes(a.status));

  const handleArtworkSelect = (id) => {
    const art = artworks.find(a => a.id===id);
    if (!art) { s("artworkId",""); return; }
    s("artworkId", id);
    s("title", art.title);
    s("artist", art.artist||"");
    s("artworkValue", art.recommendedPrice||0);
    s("reservePrice", art.recommendedPrice||0);
    s("galleryName", art.galleryName||"");
  };

  const endTimeMin = () => {
    const d = new Date();
    d.setMinutes(d.getMinutes()+30);
    return d.toISOString().slice(0,16);
  };

  return (
    <div style={{ position:"fixed", inset:0, background:"rgba(0,0,0,0.75)", zIndex:200, display:"flex", alignItems:"center", justifyContent:"center", padding:20 }}>
      <div style={{ background:"#f7f5f1", border:"1px solid rgba(182,139,46,0.30)", borderRadius:16, width:"100%", maxWidth:600, maxHeight:"90vh", overflow:"auto", padding:28 }}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:24 }}>
          <h2 style={{ fontFamily:"Cormorant Garamond,serif", fontSize:22, fontWeight:400, color:"#1a1714", margin:0 }}>Create Auction</h2>
          <button onClick={onClose} style={{ background:"none", border:"none", color:"#6b635a", cursor:"pointer", fontSize:20 }}>×</button>
        </div>

        <div style={{ marginBottom:14 }}>
          <label style={{ display:"block", fontSize:10, fontWeight:500, letterSpacing:2, textTransform:"uppercase", color:"#6b635a", marginBottom:6 }}>Select Artwork</label>
          <select value={f.artworkId} onChange={e=>handleArtworkSelect(e.target.value)} style={{ width:"100%", padding:"12px 14px", background:"#e8e4dd", border:"1px solid rgba(182,139,46,0.20)", borderRadius:8, color:"#1a1714", fontFamily:"DM Sans,sans-serif", fontSize:14, outline:"none" }}>
            <option value="">— Select artwork</option>
            {availableArtworks.map(a => <option key={a.id} value={a.id}>{a.title} — R {fmt(a.recommendedPrice)} ({a.status})</option>)}
          </select>
        </div>

        {f.artworkId && (
          <div style={{ padding:"12px 14px", background:"rgba(182,139,46,0.08)", border:"1px solid rgba(182,139,46,0.2)", borderRadius:8, marginBottom:14, fontSize:12, color:"#6b635a" }}>
            <strong>{f.title}</strong> by {f.artist} · Declared value: R {fmt(f.artworkValue)} · Gallery: {f.galleryName||"—"}
          </div>
        )}

        <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:14 }}>
          <div style={{ marginBottom:0 }}>
            <label style={{ display:"block", fontSize:10, fontWeight:500, letterSpacing:2, textTransform:"uppercase", color:"#6b635a", marginBottom:6 }}>Reserve Price (R)</label>
            <input type="number" value={f.reservePrice} onChange={e=>s("reservePrice",Number(e.target.value))} style={{ width:"100%", padding:"12px 14px", background:"#e8e4dd", border:"1px solid rgba(182,139,46,0.20)", borderRadius:8, color:"#1a1714", fontFamily:"DM Sans,sans-serif", fontSize:14, outline:"none" }}/>
            <div style={{ fontSize:10, color:"#8a8070", marginTop:4 }}>Auto-set to 100% declared value. Renter may adjust per agreement.</div>
          </div>
          <div style={{ marginBottom:0 }}>
            <label style={{ display:"block", fontSize:10, fontWeight:500, letterSpacing:2, textTransform:"uppercase", color:"#6b635a", marginBottom:6 }}>Auction End Date & Time</label>
            <input type="datetime-local" value={f.endTime} min={endTimeMin()} onChange={e=>s("endTime",e.target.value)} style={{ width:"100%", padding:"12px 14px", background:"#e8e4dd", border:"1px solid rgba(182,139,46,0.20)", borderRadius:8, color:"#1a1714", fontFamily:"DM Sans,sans-serif", fontSize:13, outline:"none" }}/>
          </div>
        </div>

        <div style={{ marginTop:14, marginBottom:14 }}>
          <label style={{ display:"block", fontSize:10, fontWeight:500, letterSpacing:2, textTransform:"uppercase", color:"#6b635a", marginBottom:10 }}>Bid Increment</label>
          <div style={{ display:"grid", gridTemplateColumns:"repeat(5,1fr)", gap:8 }}>
            {BID_INCREMENTS.map(inc => (
              <button key={inc.label} onClick={() => { s("incrementType",inc.type); s("incrementValue",inc.value); s("incrementLabel",inc.label); }} style={{ padding:"10px 6px", borderRadius:8, border:f.incrementLabel===inc.label?"2px solid #b68b2e":"1px solid rgba(182,139,46,0.25)", background:f.incrementLabel===inc.label?"rgba(182,139,46,0.18)":"#e8e4dd", color:f.incrementLabel===inc.label?"#b68b2e":"#6b635a", cursor:"pointer", fontFamily:"DM Sans,sans-serif", fontSize:12, fontWeight:f.incrementLabel===inc.label?600:400 }}>
                {inc.label}
              </button>
            ))}
          </div>
          {f.artworkValue > 0 && f.incrementValue > 0 && (
            <div style={{ fontSize:11, color:"#8a8070", marginTop:8 }}>
              Min next bid from R {fmt(f.artworkValue)}: R {fmt(calcMinBid(f.artworkValue, { type:f.incrementType, value:f.incrementValue }))}
            </div>
          )}
        </div>

        <div style={{ marginBottom:14 }}>
          <label style={{ display:"block", fontSize:10, fontWeight:500, letterSpacing:2, textTransform:"uppercase", color:"#6b635a", marginBottom:6 }}>Notes (internal)</label>
          <textarea value={f.startNote} onChange={e=>s("startNote",e.target.value)} style={{ width:"100%", padding:"12px 14px", background:"#e8e4dd", border:"1px solid rgba(182,139,46,0.20)", borderRadius:8, color:"#1a1714", fontFamily:"DM Sans,sans-serif", fontSize:14, outline:"none", minHeight:60, resize:"vertical" }} placeholder="Internal notes for this auction..."/>
        </div>

        <div style={{ display:"flex", gap:10, justifyContent:"flex-end", marginTop:8 }}>
          <button onClick={onClose} style={{ padding:"12px 22px", borderRadius:8, border:"1px solid rgba(182,139,46,0.50)", cursor:"pointer", fontSize:12, fontWeight:600, letterSpacing:1, textTransform:"uppercase", fontFamily:"DM Sans,sans-serif", background:"transparent", color:"#b68b2e" }}>Cancel</button>
          <button onClick={() => {
            if (!f.artworkId) return alert("Select an artwork");
            if (!f.endTime) return alert("Set an end date and time");
            if (!f.incrementLabel) return alert("Select a bid increment");
            onSave(f);
          }} style={{ padding:"12px 22px", borderRadius:8, border:"none", cursor:"pointer", fontSize:12, fontWeight:600, letterSpacing:1, textTransform:"uppercase", fontFamily:"DM Sans,sans-serif", background:"linear-gradient(135deg,#b68b2e,#8a6a1e)", color:"#f5f3ef" }}>
            Create Auction
          </button>
        </div>
      </div>
    </div>
  );
}

// ─── PLACE BID MODAL ───
function PlaceBidModal({ auction, buyers, bids, onBid, onClose, fmt }) {
  const [buyerId, setBuyerId] = React.useState("");
  const [customAmount, setCustomAmount] = React.useState("");
  const bn = b => b.type==="company" ? b.companyName : `${b.firstName} ${b.lastName}`;

  const minBid = calcMinBid(auction.currentBid||auction.reservePrice||0, { type:auction.incrementType, value:auction.incrementValue });
  const amount = Number(customAmount) || minBid;
  const buyer = buyers.find(b => b.id === buyerId);
  const reserveMet = amount >= (auction.reservePrice||0);

  return (
    <div style={{ position:"fixed", inset:0, background:"rgba(0,0,0,0.75)", zIndex:200, display:"flex", alignItems:"center", justifyContent:"center", padding:20 }}>
      <div style={{ background:"#f7f5f1", border:"1px solid rgba(182,139,46,0.30)", borderRadius:16, width:"100%", maxWidth:480, padding:28 }}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:20 }}>
          <h2 style={{ fontFamily:"Cormorant Garamond,serif", fontSize:22, fontWeight:400, color:"#1a1714", margin:0 }}>Place Bid</h2>
          <button onClick={onClose} style={{ background:"none", border:"none", color:"#6b635a", cursor:"pointer", fontSize:20 }}>×</button>
        </div>

        <div style={{ background:"#e8e4dd", borderRadius:10, padding:"14px 16px", marginBottom:18 }}>
          <div style={{ fontFamily:"Cormorant Garamond,serif", fontSize:18, color:"#1a1714", marginBottom:4 }}>{auction.title}</div>
          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8, fontSize:13 }}>
            <span style={{ color:"#6b635a" }}>Current bid:</span><span style={{ fontWeight:600, color:"#b68b2e" }}>R {fmt(auction.currentBid||0)}</span>
            <span style={{ color:"#6b635a" }}>Reserve:</span><span style={{ color:"#c45c4a" }}>R {fmt(auction.reservePrice||0)}</span>
            <span style={{ color:"#6b635a" }}>Min next bid:</span><span style={{ fontWeight:600, color:"#1a1714" }}>R {fmt(minBid)}</span>
            <span style={{ color:"#6b635a" }}>Increment:</span><span>{auction.incrementLabel}</span>
          </div>
        </div>

        <div style={{ marginBottom:14 }}>
          <label style={{ display:"block", fontSize:10, fontWeight:500, letterSpacing:2, textTransform:"uppercase", color:"#6b635a", marginBottom:6 }}>Bidder (KYC Approved)</label>
          <select value={buyerId} onChange={e=>setBuyerId(e.target.value)} style={{ width:"100%", padding:"12px 14px", background:"#e8e4dd", border:"1px solid rgba(182,139,46,0.20)", borderRadius:8, color:"#1a1714", fontFamily:"DM Sans,sans-serif", fontSize:14, outline:"none" }}>
            <option value="">— Select approved buyer</option>
            {buyers.map(b => <option key={b.id} value={b.id}>{bn(b)} · {b.email||""}</option>)}
          </select>
          {buyers.length === 0 && <div style={{ fontSize:11, color:"#c45c4a", marginTop:6 }}>⚠ No approved buyers. Approve buyers in the Buyer Approvals tab first.</div>}
        </div>

        <div style={{ marginBottom:18 }}>
          <label style={{ display:"block", fontSize:10, fontWeight:500, letterSpacing:2, textTransform:"uppercase", color:"#6b635a", marginBottom:6 }}>Bid Amount (R)</label>
          <input type="number" value={customAmount} onChange={e=>setCustomAmount(e.target.value)} placeholder={`Min R ${fmt(minBid)}`} style={{ width:"100%", padding:"12px 14px", background:"#e8e4dd", border:`1px solid ${amount>=minBid?"rgba(182,139,46,0.20)":"rgba(196,92,74,0.40)"}`, borderRadius:8, color:"#1a1714", fontFamily:"DM Sans,sans-serif", fontSize:14, outline:"none" }}/>
          {customAmount && amount < minBid && <div style={{ fontSize:11, color:"#c45c4a", marginTop:6 }}>⚠ Bid must be at least R {fmt(minBid)}</div>}
          {customAmount && amount >= minBid && (
            <div style={{ fontSize:11, marginTop:6, color:reserveMet?"#4a9e6b":"#c45c4a" }}>
              {reserveMet ? "✓ Reserve price met — this bid qualifies for sale" : `⚠ Below reserve (R ${fmt(auction.reservePrice)}) — bid will be recorded but artwork won't sell at this price`}
            </div>
          )}
        </div>

        <div style={{ display:"flex", gap:10, justifyContent:"flex-end" }}>
          <button onClick={onClose} style={{ padding:"12px 22px", borderRadius:8, border:"1px solid rgba(182,139,46,0.50)", cursor:"pointer", fontSize:12, fontWeight:600, letterSpacing:1, textTransform:"uppercase", fontFamily:"DM Sans,sans-serif", background:"transparent", color:"#b68b2e" }}>Cancel</button>
          <button disabled={!buyerId||amount<minBid} onClick={() => {
            if (!buyerId || amount < minBid) return;
            onBid(buyerId, bn(buyer), amount);
          }} style={{ padding:"12px 22px", borderRadius:8, border:"none", cursor:(!buyerId||amount<minBid)?"not-allowed":"pointer", fontSize:12, fontWeight:600, letterSpacing:1, textTransform:"uppercase", fontFamily:"DM Sans,sans-serif", background:"linear-gradient(135deg,#b68b2e,#8a6a1e)", color:"#f5f3ef", opacity:(!buyerId||amount<minBid)?0.4:1 }}>
            Confirm Bid — R {fmt(amount)}
          </button>
        </div>
      </div>
    </div>
  );
}

